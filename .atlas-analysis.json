  "keyFeatures": [
    "RAG-based answer generation with grounded responses",
    "ML triage classification for category and priority prediction",
    "Semantic document retrieval using Chroma vector store",
    "Structured outputs with citations and internal next steps",
    "Offline evaluation with faithfulness and adversarial testing",
    "FastAPI endpoints for ingestion and question answering",
    "Docker support for containerized deployment"
  ],
  "publicApiSurface": [
    "POST /api/v1/answer - Query RAG system for ticket answers",
    "POST /api/v1/triage - Run ML triage on ticket",
    "POST /api/v1/ingest - Ingest documents into knowledge base",
    "GET /api/v1/health - Health check endpoint",
    "SimpleRetrievalAgent.answer() - RAG agent main method",
    "TriageModel.predict() - Triage prediction method",
    "DocumentIngestor.ingest() - Document ingestion",
    "run_evaluation() - Offline evaluation runner",
    "train() - Model training function",
    "predict() - Batch prediction function"
  ]
